#!/usr/bin/env bash
set -euo pipefail

echo "== VTP Doctor =="
echo "Python: $(python3 --version 2>&1)"
echo "Config: /etc/vortexl2"
if command -v easytier-core >/dev/null 2>&1; then
  BIN="$(command -v easytier-core)"
  echo "EasyTier: $($BIN --version 2>&1 | head -1)"
  echo "EasyTier path: $BIN"
elif [[ -x /usr/local/bin/easytier-core ]]; then
  echo "EasyTier: $(/usr/local/bin/easytier-core --version 2>&1 | head -1)"
  echo "EasyTier path: /usr/local/bin/easytier-core"
else
  echo "EasyTier: missing"
  echo "Hint: run sudo bash install.sh again, or use the Install EasyTier button inside the panel."
fi
if command -v haproxy >/dev/null 2>&1; then
  echo "HAProxy: $(haproxy -v 2>&1 | head -1)"
else
  echo "HAProxy: missing"
fi
python3 - <<'PY' || true
import os, sys
sys.path.insert(0, '/opt/vortexl2')
try:
    from vortexl2.haproxy_manager import HAProxyManager
    print('Forwarding plan:', HAProxyManager().forwarding_plan())
except Exception as exc:
    print('Forwarding plan error:', exc)
PY
systemctl --no-pager --full status vortexl2-panel || true
systemctl --no-pager --full status vortexl2-forward-daemon || true
systemctl --no-pager --full status 'vortexl2-easytier-*' || true
